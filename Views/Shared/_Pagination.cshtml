@model dynamic

@{
    // Handle both PaginatedList<T> and regular types
    var pageIndex = Model?.PageIndex ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
    var hasPreviousPage = Model?.HasPreviousPage ?? false;
    var hasNextPage = Model?.HasNextPage ?? false;
    
    if (totalPages <= 1) return;
    
    // Get current query string
    var query = ViewContext.HttpContext.Request.Query;
    var queryString = "";
    
    foreach (var key in query.Keys)
    {
        if (!string.Equals(key, "page", StringComparison.OrdinalIgnoreCase))
        {
            queryString += $"&{key}={Uri.EscapeDataString(query[key]!)}";
        }
    }
}

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center mb-0">
        @* Previous button *@
        @if (hasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link" href="?@queryString.TrimStart('&')&page=@(pageIndex - 1)" aria-label="Previous">
                    <span aria-hidden="true"><i class="fas fa-chevron-left"></i></span>
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link"><i class="fas fa-chevron-left"></i></span>
            </li>
        }

        @* Page numbers *@
        @for (var i = 1; i <= totalPages; i++)
        {
            if (i == pageIndex)
            {
                <li class="page-item active">
                    <span class="page-link bg-success border-success">@i</span>
                </li>
            }
            else if (i == 1 || i == totalPages || (i >= pageIndex - 2 && i <= pageIndex + 2))
            {
                <li class="page-item">
                    <a class="page-link" href="?@queryString.TrimStart('&')&page=@i">@i</a>
                </li>
            }
            else if (i == pageIndex - 3 || i == pageIndex + 3)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
            }
        }

        @* Next button *@
        @if (hasNextPage)
        {
            <li class="page-item">
                <a class="page-link" href="?@queryString.TrimStart('&')&page=@(pageIndex + 1)" aria-label="Next">
                    <span aria-hidden="true"><i class="fas fa-chevron-right"></i></span>
                </a>
            </li>
        }
        else
        {
            <li class="page-item disabled">
                <span class="page-link"><i class="fas fa-chevron-right"></i></span>
            </li>
        }
    </ul>
</nav>
